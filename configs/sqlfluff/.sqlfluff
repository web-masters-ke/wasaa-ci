[sqlfluff]
dialect = postgres
max_line_length = 120
templater = raw
runaway_limit = 10
exclude_rules = L034, L016

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
extended_capitalisation_policy = lower

[sqlfluff:rules:layout.indent]
indent_unit = space
tab_space_size = 2
